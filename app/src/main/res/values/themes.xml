<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MoodMusicApp" parent="Theme.Material3.Dark.NoActionBar">
        <!-- Main colors -->
        <item name="colorPrimary">@color/accent_color</item>
        <item name="colorOnPrimary">@color/black</item>
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="android:statusBarColor">@color/bg_dark</item>
        <item name="android:navigationBarColor">@color/bg_dark</item>

        <!-- Material 3 Surface colors -->
        <item name="colorSurface">@color/bg_surface</item>
        <item name="colorOnSurface">@color/text_white</item>
        <item name="colorOnSurfaceVariant">@color/text_gray</item>
    </style>

    <style name="Theme.MoodMusicApp.Splash" parent="Theme.MoodMusicApp">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowNoTitle">true</item>
    </style>

    <style name="CircleImage">
        <item name="cornerSize">50%</item>
    </style>

    <style name="RoundedImage">
        <item name="cornerSize">20dp</item>
    </style>

    <style name="NeonCrystalCard">
        <item name="cornerSize">20dp</item>
    </style>
</resources>